{
  "name": "vscode-ssh-config-all-in-one",
  "displayName": "SSH Config All In One",
  "description": "Enhanced SSH config editing, providing autocompletion, formatting, hover support, and Quick Connect actions to ms-vscode-remote.remote-ssh.",
  "version": "0.1.0",
  "publisher": "hnrobert",
  "icon": "docs/images/icon.png",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hnrobert/vscode-ssh-config-all-in-one"
  },
  "engines": {
    "vscode": "^1.83.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "keywords": [
    "remote development",
    "remote",
    "vscode ssh"
  ],
  "main": "./out/extension.js",
  "enabledApiProposals": [
    "contribViewsRemote"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "languages": [
      {
        "id": "ssh_config",
        "aliases": [
          "SSH Config"
        ],
        "extensions": [
          "ssh_config"
        ],
        "filenames": [
          "config",
          "sshd_config"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "SSH Config All In One",
      "properties": {
        "sshConfigAllInOne.format.indentSize": {
          "type": "integer",
          "default": 2,
          "markdownDescription": "The number of spaces used for indentation"
        }
      }
    },
    "views": {
      "remote": [
        {
          "id": "ssh-explorer-hosts",
          "name": "SSH Config Hosts",
          "group": "targets@2"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-ssh-config-all-in-one.openUserConfig",
        "title": "SSH: Open User Configuration"
      },
      {
        "command": "ssh-explorer.refresh",
        "title": "SSH Explorer: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ssh-explorer.connectCurrentWindow",
        "title": "Connect in Current Window",
        "icon": "$(arrow-right)"
      },
      {
        "command": "ssh-explorer.connectNewWindow",
        "title": "Connect in New Window",
        "icon": "$(empty-window)"
      },
      {
        "command": "ssh-explorer.connectFolderCurrentWindow",
        "title": "Connect Folder in Current Window",
        "icon": "$(arrow-right)"
      },
      {
        "command": "ssh-explorer.connectFolderNewWindow",
        "title": "Connect Folder in New Window",
        "icon": "$(empty-window)"
      },
      {
        "command": "ssh-explorer.revealHost",
        "title": "SSH Explorer: Reveal Host"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ssh-explorer.refresh",
          "when": "view == ssh-explorer-hosts",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ssh-explorer.connectCurrentWindow",
          "when": "view == ssh-explorer-hosts && viewItem == host",
          "group": "inline"
        },
        {
          "command": "ssh-explorer.connectNewWindow",
          "when": "view == ssh-explorer-hosts && viewItem == host",
          "group": "inline"
        },
        {
          "command": "ssh-explorer.connectFolderCurrentWindow",
          "when": "view == ssh-explorer-hosts && viewItem == folder",
          "group": "inline"
        },
        {
          "command": "ssh-explorer.connectFolderNewWindow",
          "when": "view == ssh-explorer-hosts && viewItem == folder",
          "group": "inline"
        }
      ]
    },
    "grammars": [
      {
        "scopeName": "source.config.ssh.injection",
        "path": "./syntaxes/ssh_config.tmLanguage.json",
        "injectTo": [
          "source.config.ssh"
        ]
      }
    ]
  },
  "scripts": {
    "publish": "vsce package --no-dependencies",
    "vscode:prepublish": "pnpm run build",
    "build": "tsup",
    "watch": "tsup --watch",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/node": "~20.11.25",
    "@types/vscode": "^1.83.0",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "tsup": "^8.5.0",
    "typescript": "5.2.2"
  }
}